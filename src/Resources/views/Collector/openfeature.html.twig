{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block toolbar %}
    {% set icon %}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="5" width="22" height="14" rx="7" ry="7"/><circle cx="16" cy="12" r="3"/>
        </svg>
        <span class="sf-toolbar-value">{{ collector.evaluationCount }}</span>
    {% endset %}

    {% set text %}
        <div class="sf-toolbar-info-piece">
            <b>Provider</b>
            <span>{{ collector.provider }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Flags evaluated</b>
            <span class="sf-toolbar-status">{{ collector.evaluationCount }}</span>
        </div>
    {% endset %}

    {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: profiler_url }) }}
{% endblock %}

{% block menu %}
    <span class="label">
        <span class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="5" width="22" height="14" rx="7" ry="7"/><circle cx="16" cy="12" r="3"/>
            </svg>
        </span>
        <strong>OpenFeature</strong>
        {% if collector.evaluationCount > 0 %}
            <span class="count">
                <span>{{ collector.evaluationCount }}</span>
            </span>
        {% endif %}
    </span>
{% endblock %}

{% block panel %}
    <h2>OpenFeature</h2>

    <div class="metrics">
        <div class="metric">
            <span class="value">{{ collector.provider }}</span>
            <span class="label">Provider</span>
        </div>
        <div class="metric">
            <span class="value">{{ collector.evaluationCount }}</span>
            <span class="label">Flags evaluated</span>
        </div>
    </div>

    {% if collector.evaluationContext is not empty %}
        <h3>Evaluation Context</h3>
        <table>
            <thead>
                <tr>
                    <th>Key</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                {% if collector.evaluationContext.targeting_key %}
                    <tr>
                        <td><code>targeting_key</code></td>
                        <td>{{ collector.evaluationContext.targeting_key }}</td>
                    </tr>
                {% endif %}
                {% for key, value in collector.evaluationContext.attributes ?? {} %}
                    <tr>
                        <td><code>{{ key }}</code></td>
                        <td>{{ value }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <h3>Context Providers</h3>

    {% if collector.contextProviders is empty %}
        <div class="empty">
            <p>No context provider contributed during this request.</p>
        </div>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>Provider</th>
                    <th>Targeting key</th>
                    <th>Attributes</th>
                </tr>
            </thead>
            <tbody>
                {% for contribution in collector.contextProviders %}
                    <tr>
                        <td><code>{{ contribution.provider }}</code></td>
                        <td>{{ contribution.targeting_key ?? '-' }}</td>
                        <td>
                            {% if contribution.attributes is empty %}
                                -
                            {% else %}
                                {% for key, value in contribution.attributes %}
                                    <code>{{ key }}</code>: {{ value }}{{ not loop.last ? ', ' : '' }}
                                {% endfor %}
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <h3>Registered Hooks</h3>

    {% if collector.hooks is empty %}
        <div class="empty">
            <p>No hooks are registered.</p>
        </div>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>Hook</th>
                </tr>
            </thead>
            <tbody>
                {% for hook in collector.hooks %}
                    <tr>
                        <td><code>{{ hook }}</code></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <h3>Flag Evaluations</h3>

    {% if collector.evaluations is empty %}
        <div class="empty">
            <p>No flags were evaluated during this request.</p>
        </div>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>Flag</th>
                    <th>Type</th>
                    <th>Value</th>
                    <th>Variant</th>
                    <th>Reason</th>
                    <th>Error</th>
                </tr>
            </thead>
            <tbody>
                {% for eval in collector.evaluations %}
                    <tr class="{{ eval.error ? 'status-error' : '' }}">
                        <td><code>{{ eval.flag }}</code></td>
                        <td>{{ eval.type }}</td>
                        <td>
                            {% if eval.value is same as true %}
                                <span class="label status-success">true</span>
                            {% elseif eval.value is same as false %}
                                <span class="label status-warning">false</span>
                            {% else %}
                                {{ eval.value|e }}
                            {% endif %}
                        </td>
                        <td>{{ eval.variant ?? '-' }}</td>
                        <td>{{ eval.reason ?? '-' }}</td>
                        <td>{{ eval.error|default('-')|e }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
